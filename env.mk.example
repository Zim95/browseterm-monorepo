# ─────────────────────────────────────────────────────────────────────────────
# BrowseTerm — AGGREGATED config (single source of truth for the whole stack).
#
# Copy this to `env.mk` (gitignored) and fill in the secrets. `make setup` /
# `scripts/gen-env.sh` fan these values out into each submodule's own env.mk/.env
# (with the var names each repo expects) and then deploy in order.
#
# Format is `VAR=value` (no spaces) so the file is valid for BOTH `make include`
# and bash `source`. Per-service values are PREFIXED.
# ─────────────────────────────────────────────────────────────────────────────

# ── Shared ──
NAMESPACE=browseterm
REPO_NAME=zim95
USER_NAME=zim95
# Docker Hub push credential (used for non-interactive `docker login` before builds).
# NOTE: at runtime each USER pushes snapshots to their OWN repo — this is just the
# build/push identity for the shared in-cluster images.
REPO_PASSWORD=CHANGEME_DOCKERHUB_TOKEN

# ── MetalLB pool (must match the node subnet; Docker Desktop = 192.168.65.x) ──
METALLB_POOL=192.168.65.200-192.168.65.250

# ── Local access hostnames (map these in /etc/hosts — see 00_docs/local_ip_setup.md) ──
INGRESS_HOST=browseterm.local.com
SOCKET_SSH_HOST=socketssh.local
SOCKET_SSH_WSS_URL=ws://socketssh.local:8000
AUTH_REDIRECT_BASE_URI=http://localhost:9999

# ── Postgres (postgres_ha) ──
PG_USER=browseterm
PG_PASSWORD=browseterm-dev-pw
PG_DB=browseterm
PG_TEST_DB=browseterm_test

# ── Redis (redis_ha) ──
REDIS_USER=browseterm
REDIS_PASSWORD=redis-dev-pw
REDIS_DATA_DIR=browseterm
REDIS_DB=0

# ── MinIO (container-maker + snapshot job) ──
STORAGE_LAYER=minio
MINIO_ENDPOINT=minio-service:9000
MINIO_BUCKET=browseterm-snapshots
MINIO_SECURE=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123

# ── browseterm-server OAuth (per-app secrets) ──
SERVER_GOOGLE_CLIENT_ID=CHANGEME_GOOGLE_CLIENT_ID
SERVER_GOOGLE_CLIENT_SECRET=CHANGEME_GOOGLE_CLIENT_SECRET
SERVER_GITHUB_CLIENT_ID=CHANGEME_GITHUB_CLIENT_ID
SERVER_GITHUB_CLIENT_SECRET=CHANGEME_GITHUB_CLIENT_SECRET

# ── Constants (rarely change; defaults baked into gen-env.sh if omitted) ──
CONTAINER_MAKER_CERTS_SECRET_NAME=container-maker-development-service-certs
CERT_MANAGER_CRON_JOB_NAME=cert-manager
